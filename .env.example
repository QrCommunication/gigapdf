# =============================================================================
# Application Configuration
# =============================================================================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://gigapdf:gigapdf@localhost:5432/gigapdf
DATABASE_POOL_SIZE=20

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Authentication (External JWT)
# =============================================================================
# Can be a PEM public key or JWKS URL
AUTH_JWT_PUBLIC_KEY=your-jwt-public-key-or-jwks-url
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=giga-pdf

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE_PATH=/var/lib/gigapdf/documents
STORAGE_MAX_SIZE_GB=100

# =============================================================================
# OCR Configuration (Tesseract)
# =============================================================================
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/5/tessdata
OCR_DEFAULT_LANGUAGES=fra+eng

# =============================================================================
# PDF Engine (Next.js web — TypeScript)
# =============================================================================
# Embed custom fonts (original PDF fonts converted via fontforge, or fonts
# downloaded on demand from Google Fonts) into the final PDF when baking
# text edits. Disabled when unset. Requires `fontforge` on the host
# (already bundled in the Docker web image).
FONT_EMBED_CUSTOM_ENABLED=true

# Internal URL the Celery worker uses to reach the Next.js TS engine, plus the
# shared secret authenticating those server-to-server calls (e.g. the export
# worker calling /api/pdf/preview, which requires auth). INTERNAL_API_SECRET
# MUST be identical in the Python (.env) and Next.js environments — the same
# .env is symlinked for apps/web in production. Generate: openssl rand -hex 32
NEXTJS_INTERNAL_URL=http://localhost:3000
INTERNAL_API_SECRET=change-me-min-32-chars-use-openssl-rand-hex-32

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=db+postgresql://gigapdf:gigapdf@localhost:5432/gigapdf_celery
JOB_TIMEOUT_SECONDS=3600
ASYNC_THRESHOLD_MB=10

# =============================================================================
# Limits
# =============================================================================
MAX_UPLOAD_SIZE_MB=250
MAX_PAGES_PER_DOCUMENT=5000
PREVIEW_MAX_DPI=600
HISTORY_MAX_STATES=100

# =============================================================================
# WebSocket Configuration
# =============================================================================
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/2

# =============================================================================
# Email Configuration (Resend)
# =============================================================================
# Transactional emails are sent through Resend (https://resend.com).
# Get an API key at https://resend.com/api-keys (server-only, never NEXT_PUBLIC_*).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender. The domain of EMAIL_FROM MUST be verified in Resend.
EMAIL_FROM=noreply@giga-pdf.com
MAIL_FROM_NAME=GigaPDF

# Reply-To shown to recipients (support inbox).
EMAIL_REPLY_TO=support@giga-pdf.com

# Absolute production URLs used inside emails (logo + links). These must NOT
# point to localhost — NEXT_PUBLIC_APP_URL is inlined as localhost in bundles.
EMAIL_BASE_URL=https://giga-pdf.com
EMAIL_APP_URL=https://giga-pdf.com

# Frontend URL for email links (password reset, verification, etc.)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Stripe Configuration
# =============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Webhook secret from https://dashboard.stripe.com/webhooks
# Configure webhook URL: https://your-domain.com/webhooks/stripe
# Events to enable:
#   - checkout.session.completed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - customer.subscription.trial_will_end
#   - invoice.paid
#   - invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# NOTE: Price IDs are managed in the database (plans table)
# The billing queue automatically syncs plans to Stripe
# Run: celery -A app.tasks.celery_app worker -Q billing
# Products and prices will be created/updated automatically
