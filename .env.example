# =============================================================================
# Application Configuration
# =============================================================================
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-in-production-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://gigapdf:gigapdf@localhost:5432/gigapdf
DATABASE_POOL_SIZE=20

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Authentication (External JWT)
# =============================================================================
# Can be a PEM public key or JWKS URL
AUTH_JWT_PUBLIC_KEY=your-jwt-public-key-or-jwks-url
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ISSUER=https://auth.example.com
AUTH_JWT_AUDIENCE=giga-pdf

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE_PATH=/var/lib/gigapdf/documents
STORAGE_MAX_SIZE_GB=100

# =============================================================================
# OCR Configuration (Tesseract)
# =============================================================================
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/5/tessdata
OCR_DEFAULT_LANGUAGES=fra+eng

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=db+postgresql://gigapdf:gigapdf@localhost:5432/gigapdf_celery
JOB_TIMEOUT_SECONDS=3600
ASYNC_THRESHOLD_MB=10

# =============================================================================
# Limits
# =============================================================================
MAX_UPLOAD_SIZE_MB=500
MAX_PAGES_PER_DOCUMENT=5000
PREVIEW_MAX_DPI=600
HISTORY_MAX_STATES=100

# =============================================================================
# WebSocket Configuration
# =============================================================================
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/2

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================
# SMTP server settings
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=GigaPDF

# Security settings (choose one: TLS or SSL)
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_STARTTLS=true

# Optional: Timeout in seconds
MAIL_TIMEOUT=30

# Frontend URL for email links (password reset, verification, etc.)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Stripe Configuration
# =============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Webhook secret from https://dashboard.stripe.com/webhooks
# Configure webhook URL: https://your-domain.com/webhooks/stripe
# Events to enable:
#   - checkout.session.completed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - customer.subscription.trial_will_end
#   - invoice.paid
#   - invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# NOTE: Price IDs are managed in the database (plans table)
# The billing queue automatically syncs plans to Stripe
# Run: celery -A app.tasks.celery_app worker -Q billing
# Products and prices will be created/updated automatically
