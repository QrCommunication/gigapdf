# GigaPDF - Web Frontend (Next.js 16) + moteur PDF TypeScript
#
# Base Debian (bookworm) — image glibc :
#   - node-canvas et sharp disposent de prebuilds glibc (aucune toolchain requise)
#
# AUCUN binaire système tiers n'est requis : le moteur PDF (gigapdf-lib, WebAssembly)
# est autonome. Il gère en interne les conversions Office ↔ PDF et HTML/URL → PDF,
# l'OCR multi-langues, l'embarquement et la conversion des polices, la rasterisation,
# les signatures et le chiffrement — sans LibreOffice, Chromium/Playwright, Tesseract,
# fontforge ni poppler.

FROM node:22-bookworm-slim AS base

RUN corepack enable && corepack prepare pnpm@10.28.0 --activate

# ============================================
# Builder stage
# ============================================
FROM base AS builder

WORKDIR /app

# Sans TTY, pnpm refuse de purger le node_modules issu de `pnpm fetch`
# (ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY) — CI=true lève la confirmation.
ENV CI=true

# Couche cache dépendances : seule une modification du lockfile invalide ce layer.
# `pnpm fetch` ne lit QUE le lockfile (pas besoin d'énumérer les package.json
# de chaque workspace — source d'erreurs quand le monorepo évolue).
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
RUN pnpm fetch

# Code source complet (le .dockerignore exclut .env, node_modules, .next, .git)
COPY . .

# Install offline depuis le store pré-rempli. Les postinstall autorisés
# (onlyBuiltDependencies : canvas, sharp, @prisma/engines…) gardent l'accès réseau.
RUN pnpm install --frozen-lockfile --offline

# Client Prisma
RUN pnpm --filter web db:generate

# Build : turbo ordonne les packages internes puis l'app web
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm exec turbo run build --filter=web...

# ============================================
# Production stage
# ============================================
FROM node:22-bookworm-slim AS production

WORKDIR /app

# Dépendances système minimales (le moteur PDF wasm n'exige aucun binaire tiers) :
#   - ca-certificates : TLS sortant (téléchargement des Google Fonts, accès S3)
#   - dumb-init : gestion des signaux en PID 1
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    dumb-init \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /root/.npm

# Utilisateur non-root avec HOME inscriptible
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 --ingroup nodejs --home /home/nextjs nextjs

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME="0.0.0.0" \
    HOME=/home/nextjs

# Build standalone Next.js (outputFileTracingRoot = racine monorepo, donc
# server.js vit sous apps/web/). public/ et .next/static doivent être des
# SIBLINGS de server.js — PAS à la racine de /app.
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

USER nextjs

# fetch natif Node 22 — wget/curl inutiles dans l'image.
# /api/health est un session-check : 401 sans session = serveur SAIN ;
# seul un 5xx (DB down, crash) ou l'absence de réponse est unhealthy.
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD node -e "fetch('http://127.0.0.1:3000/api/health').then(r=>process.exit(r.status<500?0:1)).catch(()=>process.exit(1))"

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "apps/web/server.js"]
