{
  "name": "@giga-pdf/canvas",
  "license": "PolyForm-Noncommercial-1.0.0",
  "version": "0.1.0",
  "description": "Fabric.js-based canvas for PDF rendering and editing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo \"[$npm_package_name] lint delegated to consuming apps\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@giga-pdf/types": "workspace:*",
    "@qrcommunication/gigapdf-lib": "^0.62.0",
    "fabric": "^7.4.0"
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/types": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
