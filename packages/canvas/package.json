{
  "name": "@giga-pdf/canvas",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "description": "Fabric.js-based canvas for PDF rendering and editing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@giga-pdf/types": "workspace:*",
    "fabric": "^7.1.0",
    "pdfjs-dist": "^5.4.530"
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/types": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
