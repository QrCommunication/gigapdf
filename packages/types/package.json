{
  "name": "@giga-pdf/types",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.mjs",
      "require": "./dist/models/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js"
    },
    "./websocket": {
      "types": "./dist/websocket/index.d.ts",
      "import": "./dist/websocket/index.mjs",
      "require": "./dist/websocket/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/models/index.ts src/api/index.ts src/websocket/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/models/index.ts src/api/index.ts src/websocket/index.ts --format cjs,esm --dts --watch",
    "lint": "echo \"[$npm_package_name] lint delegated to consuming apps\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@giga-pdf/typescript-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
