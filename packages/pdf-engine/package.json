{
  "name": "@giga-pdf/pdf-engine",
  "license": "PolyForm-Noncommercial-1.0.0",
  "version": "0.1.0",
  "description": "PDF manipulation engine for GigaPDF — parse, render, merge, encrypt, preview",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js",
      "require": "./dist/engine/index.cjs"
    },
    "./parse": {
      "types": "./dist/parse/index.d.ts",
      "import": "./dist/parse/index.js",
      "require": "./dist/parse/index.cjs"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js",
      "require": "./dist/render/index.cjs"
    },
    "./merge-split": {
      "types": "./dist/merge-split/index.d.ts",
      "import": "./dist/merge-split/index.js",
      "require": "./dist/merge-split/index.cjs"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js",
      "require": "./dist/forms/index.cjs"
    },
    "./encrypt": {
      "types": "./dist/encrypt/index.d.ts",
      "import": "./dist/encrypt/index.js",
      "require": "./dist/encrypt/index.cjs"
    },
    "./preview": {
      "types": "./dist/preview/index.d.ts",
      "import": "./dist/preview/index.js",
      "require": "./dist/preview/index.cjs"
    },
    "./convert": {
      "types": "./dist/convert/index.d.ts",
      "import": "./dist/convert/index.js",
      "require": "./dist/convert/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run __tests__/integration",
    "lint": "echo \"[$npm_package_name] lint delegated to consuming apps\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "fixtures:generate": "tsx __tests__/fixtures/create-fixtures.ts"
  },
  "dependencies": {
    "@giga-pdf/types": "workspace:*",
    "@qrcommunication/gigapdf-lib": "^0.62.0"
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "pdfjs-dist": "5.7.284",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
