{
  "name": "@giga-pdf/editor",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@giga-pdf/logger": "workspace:*",
    "@giga-pdf/types": "workspace:*",
    "immer": "^11.1.3",
    "zustand": "^5.0.10"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "socket.io-client": "^4.7.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "socket.io-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
