{
  "name": "@giga-pdf/editor",
  "license": "PolyForm-Noncommercial-1.0.0",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "echo \"[$npm_package_name] lint delegated to consuming apps\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@giga-pdf/logger": "workspace:*",
    "@giga-pdf/types": "workspace:*",
    "immer": "^11.1.8",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "socket.io-client": "^4.7.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "socket.io-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
