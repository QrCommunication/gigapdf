#!/usr/bin/env sh
# Pre-commit hook: bloque les anti-patterns qui ont casse la prod
#
# Pourquoi : 3 bugs runtime silencieux qui ont chacun necessite un debug
# douloureux en prod sur giga-pdf.com. Aucun de ces patterns n'est detecte
# par tsc / ESLint / mypy / Ruff avec config standard.
#
# Pour bypasser un faux positif legitime : git commit --no-verify
# Mais ARRETER d'abord 5 secondes pour verifier que c'est vraiment un FP.

set -e

# Couleurs ANSI (printf pour compat Linux/macOS)
RED=$(printf '\033[1;31m')
YEL=$(printf '\033[1;33m')
DIM=$(printf '\033[0;90m')
RST=$(printf '\033[0m')

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED" ]; then
  exit 0
fi

VIOLATIONS=0

print_header() {
  if [ "$VIOLATIONS" -eq 0 ]; then
    printf '\n'
    printf '%s======================================================%s\n' "$RED" "$RST"
    printf '%s  COMMIT BLOQUE — Anti-patterns prod-breaking detectes%s\n' "$RED" "$RST"
    printf '%s======================================================%s\n' "$RED" "$RST"
  fi
}

# Check pattern dans contenu STAGED (pas working tree)
# Args : file, regex, label, why, fix
check_pattern() {
  file=$1
  regex=$2
  label=$3
  why=$4
  fix=$5

  matches=$(git show ":$file" 2>/dev/null | grep -nE "$regex" || true)
  if [ -n "$matches" ]; then
    print_header
    printf '\n'
    printf '%s[%s]%s %s\n' "$YEL" "$label" "$RST" "$file"
    printf '  %sPourquoi:%s %s\n' "$YEL" "$RST" "$why"
    printf '  %sFix:%s      %s\n' "$YEL" "$RST" "$fix"
    printf '  %sLignes:%s\n' "$YEL" "$RST"
    printf '%s\n' "$matches" | sed "s/^/    ${DIM}/" | sed "s/$/${RST}/"
    VIOLATIONS=$((VIOLATIONS + 1))
  fi
}

for file in $STAGED; do
  case "$file" in
    # ----- TypeScript : obj.constructor.name minifie en prod -----
    *.ts|*.tsx)
      # Skip ce hook lui-meme et les commentaires de doc qui mentionnent le pattern
      check_pattern "$file" \
        '^[^/*]*\.constructor\.name' \
        'TS-CONSTRUCTOR-NAME' \
        'Turbopack/Webpack minifient les noms de classe en prod (IText -> "t")' \
        'Pour Fabric.js : utiliser obj.type ("i-text", "rect", etc.). Sinon : type guard explicite.'
      ;;

    # ----- Python logging : extra={"name": ...} ecrase LogRecord.name -----
    *.py)
      check_pattern "$file" \
        'extra\s*=\s*\{[^}]*["'\'']name["'\'']\s*:' \
        'PY-LOGGING-NAME' \
        'extra={"name": ...} declenche KeyError "Attempt to overwrite name in LogRecord"' \
        'Renommer en document_name, user_name, resource_name, etc.'

      # ----- SQLAlchemy : not <Model>.<column> -> WHERE False -----
      # Pattern : `not Word.is_xxx` ou `not Word.<colonne booleenne typique>`
      check_pattern "$file" \
        'not [A-Z][A-Za-z0-9_]*\.(is_[a-z_]+|active|enabled|archived|published|verified|public|hidden|locked|featured|pinned|default|completed|approved|rejected)\b' \
        'PY-SQLALCHEMY-NOT-COLUMN' \
        'not <Column> = False (Column SQLAlchemy est truthy) -> WHERE False -> 0 rows' \
        'Utiliser ~Model.column ou Model.column.is_(False) ou Model.column == False'
      ;;
  esac
done

if [ "$VIOLATIONS" -gt 0 ]; then
  printf '\n'
  printf '%s======================================================%s\n' "$RED" "$RST"
  printf '%s  %d violation(s) — commit refuse%s\n' "$RED" "$VIOLATIONS" "$RST"
  printf '%s======================================================%s\n' "$RED" "$RST"
  printf '\n'
  printf 'Refs prod-breaking :\n'
  printf '  - TS-CONSTRUCTOR-NAME    : commits 5cbafe8..HEAD (properties panel vide en prod)\n'
  printf '  - PY-LOGGING-NAME        : commit 0b09fd4 (HTTP 500 sur upload documents)\n'
  printf '  - PY-SQLALCHEMY-NOT-COL  : commit 0b09fd4 (explorer documents vide, 30 sites fixes)\n'
  printf '\n'
  printf 'Faux positif certain ? Bypass : %sgit commit --no-verify%s\n' "$YEL" "$RST"
  printf '\n'
  exit 1
fi
