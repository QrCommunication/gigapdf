# =============================================================================
# Application Configuration - PRODUCTION
# =============================================================================
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS_SECURE_KEY
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# =============================================================================
# Database Configuration (Private Network)
# =============================================================================
DATABASE_URL=postgresql://rlicha:YOUR_PASSWORD_HERE
DATABASE_POOL_SIZE=20

# =============================================================================
# Redis Configuration (Private Network)
# =============================================================================
REDIS_URL=redis://172.16.8.4:6379/0

# =============================================================================
# Authentication (External JWT)
# =============================================================================
AUTH_JWT_PUBLIC_KEY=CONFIGURE_YOUR_JWT_PUBLIC_KEY
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_ISSUER=https://giga-pdf.com
AUTH_JWT_AUDIENCE=giga-pdf

# =============================================================================
# Storage Configuration
# =============================================================================
STORAGE_PATH=/var/lib/gigapdf/documents
STORAGE_MAX_SIZE_GB=100

# =============================================================================
# OCR Configuration (Tesseract)
# =============================================================================
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/5/tessdata
OCR_DEFAULT_LANGUAGES=fra+eng

# =============================================================================
# Celery Configuration
# =============================================================================
CELERY_BROKER_URL=redis://172.16.8.4:6379/1
CELERY_RESULT_BACKEND=db+postgresql://rlicha:YOUR_PASSWORD_HERE
JOB_TIMEOUT_SECONDS=3600
ASYNC_THRESHOLD_MB=10

# =============================================================================
# Limits
# =============================================================================
MAX_UPLOAD_SIZE_MB=100
MAX_PAGES_PER_DOCUMENT=5000
PREVIEW_MAX_DPI=600
HISTORY_MAX_STATES=100

# =============================================================================
# WebSocket Configuration
# =============================================================================
SOCKETIO_MESSAGE_QUEUE=redis://172.16.8.4:6379/2

# =============================================================================
# S3 Configuration (Scaleway)
# =============================================================================
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
S3_BUCKET_NAME=gigapdf
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_REGION=fr-par

# =============================================================================
# Email Configuration (SMTP)
# =============================================================================
MAIL_SERVER=mail.giga-pdf.com
MAIL_PORT=465
MAIL_USERNAME=nepasrepondre@giga-pdf.com
MAIL_PASSWORD=YOUR_PASSWORD_HERE
MAIL_FROM_EMAIL=nepasrepondre@giga-pdf.com
MAIL_FROM_NAME=GigaPDF
MAIL_USE_SSL=true
MAIL_TIMEOUT=30

# =============================================================================
# Frontend URLs
# =============================================================================
FRONTEND_URL=https://giga-pdf.com

# Next.js Public Variables
NEXT_PUBLIC_API_URL=https://giga-pdf.com/api
NEXT_PUBLIC_WS_URL=wss://giga-pdf.com
NEXT_PUBLIC_APP_URL=https://giga-pdf.com
NEXT_PUBLIC_ADMIN_URL=https://giga-pdf.com/admin

# =============================================================================
# Stripe Configuration
# =============================================================================
STRIPE_PUBLIC=YOUR_STRIPE_PUBLIC_KEY
STRIPE_SECRET=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK=

# =============================================================================
# Scaleway API Configuration (for billing/infrastructure monitoring)
# Get these from: https://console.scaleway.com/iam/api-keys
# =============================================================================
SCW_ACCESS_KEY=YOUR_SCW_ACCESS_KEY
SCW_SECRET_KEY=YOUR_SCW_SECRET_KEY
SCW_DEFAULT_ORGANIZATION_ID=YOUR_SCW_ORG_ID
SCW_DEFAULT_PROJECT_ID=YOUR_SCW_PROJECT_ID
SCW_DEFAULT_REGION=fr-par
SCW_DEFAULT_ZONE=fr-par-1
