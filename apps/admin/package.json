{
  "name": "admin",
  "license": "AGPL-3.0-or-later",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:https": "node server-https.mjs",
    "build": "prisma generate && next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "type-check": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate || true",
    "clean": "rm -rf .next",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed:admin": "tsx scripts/seed-super-admin.ts",
    "create:admin": "tsx scripts/create-super-admin.ts",
    "setup": "pnpm db:generate && pnpm db:push && pnpm seed:admin"
  },
  "dependencies": {
    "@giga-pdf/api": "workspace:*",
    "@giga-pdf/types": "workspace:*",
    "@giga-pdf/ui": "workspace:*",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.562.0",
    "next": "^16.1.2",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/tailwind-config": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "prisma": "^7.2.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
