  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:https": "node server-https.mjs",
    "build": "prisma generate && next build",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "type-check": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate || true",
    "clean": "rm -rf .next",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed:admin": "tsx scripts/seed-super-admin.ts",
    "create:admin": "tsx scripts/create-super-admin.ts",
    "setup": "pnpm db:generate && pnpm db:push && pnpm seed:admin"
  },
  "dependencies": {
    "@giga-pdf/api": "workspace:*",
    "@giga-pdf/types": "workspace:*",
    "@giga-pdf/ui": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.18",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@giga-pdf/eslint-config": "workspace:*",
    "@giga-pdf/tailwind-config": "workspace:*",
    "@giga-pdf/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.16",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
